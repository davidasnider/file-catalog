# LLM Provider Configurations

# Primary LLM and Vision Providers (llama_cpp, mlx, gemini, openai)
LLM_PROVIDER=openai
VISION_PROVIDER=openai

# Model paths/names
LLM_MODEL_PATH=mlx-community/Qwen3.6-35B-A3B-4bit
VISION_MODEL_PATH=mlx-community/Qwen3.6-35B-A3B-4bit

# OpenAI Compatible Endpoint (e.g. vLLM, Ollama, MLX-LM server)
OPENAI_BASE_URL=http://127.0.0.1:8000/v1
OPENAI_API_KEY=sk-no-key-required

VISION_MAX_PIXELS=1048576

# Cloud Options
USE_CLOUD_FALLBACK=False
USE_DOCUMENT_AI=False

# Google Cloud Vertex AI / Document AI configuration
# You must provide your Google Cloud Project ID and Vertex AI compatible credentials
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Optional API Key (If not using Application Default Credentials via `gcloud auth application-default login`)
VERTEX_API_KEY=

# Document AI
# Set your specific Processor ID created in the Google Cloud Console for extraction
DOCUMENT_AI_LOCATION=us
DOC_AI_PROCESSOR_ID=your-processor-id
